# Local environment for Mac App Store builds.
# Copy to .env.local and fill in your team's values. .env.local is gitignored.
# Sourced by scripts/build-mas.sh.

# 10-character developer team identifier (visible in Apple Developer Portal under Membership)
APPLE_TEAM_ID=

# Full code-signing identity strings as they appear in `security find-identity -v -p codesigning`.
# The "Application" identity signs the .app; the "Installer" identity signs the .pkg.
APPLE_SIGNING_IDENTITY="3rd Party Mac Developer Application: <Your Name> (TEAMID)"
APPLE_INSTALLER_IDENTITY="3rd Party Mac Developer Installer: <Your Name> (TEAMID)"

# Absolute path to the Mac App Store provisioning profile for com.onekeepass.
# Download from Apple Developer Portal → Profiles. Keep outside the repo.
MAS_PROVISION_PROFILE="$HOME/Library/MobileDevice/Provisioning Profiles/OneKeePass_MAS.provisionprofile"

# OPTIONAL — only needed when uploading to App Store Connect from an account
# enrolled in multiple teams. Single-team accounts can leave this blank;
# altool/Transporter auto-detect. To find it (when needed):
#   xcrun altool --list-providers -u "$APPLE_ID" -p "$APPLE_APP_SPECIFIC_PASSWORD"
# Used later in the upload step (xcrun altool --upload-app -asc-provider ...).
APPLE_PROVIDER_SHORT_NAME=

# Local-launch (Mac Development) signing material — used when BUILD_FOR=dev.
# Distinct from APPLE_SIGNING_IDENTITY / MAS_PROVISION_PROFILE which are for
# the Mac App Distribution build uploaded to App Store Connect.
APPLE_DEV_SIGNING_IDENTITY="Apple Development: Your Name (TEAMID)"
MAS_DEV_PROVISION_PROFILE="$HOME/Library/MobileDevice/Provisioning Profiles/OneKeePass_MacDev.provisionprofile"